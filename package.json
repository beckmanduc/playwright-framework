{
  "name": "playwright-framework",
  "version": "1.0.0",
  "description": "Playwright test automation framework",
  "scripts": {
    "test": "npx playwright test --config=config/playwright.config.ts",
    "test:headed": "npx playwright test --config=config/playwright.config.ts --headed",
    "test:debug": "npx playwright test --config=config/playwright.config.ts --debug",
    "test:ui": "npx playwright test --config=config/playwright.config.ts --ui",
    "report": "npx playwright show-report reports/html",
    "allure:generate": "npx allure generate allure-results --clean -o allure-report",
    "allure:open": "npx allure open allure-report",
    "allure:report": "npm run allure:generate && npm run allure:open"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.6.0"
  }
}
